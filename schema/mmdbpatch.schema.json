{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/ipanalytics/MMDBpatch/main/schema/mmdbpatch.schema.json",
  "title": "MMDBpatch patch file",
  "type": "object",
  "additionalProperties": false,
  "required": ["patches"],
  "properties": {
    "defaults": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "conflict": {
          "$ref": "#/$defs/conflict"
        }
      }
    },
    "patches": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/patch"
      }
    }
  },
  "$defs": {
    "conflict": {
      "type": "string",
      "enum": ["patch_wins", "first_wins", "fail_on_overlap"]
    },
    "cidr": {
      "type": "string",
      "pattern": "^([0-9]{1,3}\\.){3}[0-9]{1,3}/[0-9]{1,2}$|^[0-9A-Fa-f:]+/[0-9]{1,3}$"
    },
    "fieldPath": {
      "type": "string",
      "pattern": "^[A-Za-z0-9_][A-Za-z0-9_.-]*$"
    },
    "scalar": {
      "type": ["string", "number", "integer", "boolean", "null"]
    },
    "value": {
      "oneOf": [
        {
          "$ref": "#/$defs/scalar"
        },
        {
          "type": "array",
          "items": {
            "$ref": "#/$defs/value"
          }
        },
        {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/value"
          }
        }
      ]
    },
    "setMap": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "$ref": "#/$defs/value"
      }
    },
    "patch": {
      "type": "object",
      "additionalProperties": false,
      "required": ["cidr", "op"],
      "properties": {
        "cidr": {
          "$ref": "#/$defs/cidr"
        },
        "op": {
          "type": "string",
          "enum": ["merge", "replace", "delete_field", "delete_record", "delete"]
        },
        "conflict": {
          "$ref": "#/$defs/conflict"
        },
        "set": {
          "$ref": "#/$defs/setMap"
        },
        "field": {
          "$ref": "#/$defs/fieldPath"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "op": {
                "enum": ["merge", "replace"]
              }
            },
            "required": ["op"]
          },
          "then": {
            "required": ["set"]
          }
        },
        {
          "if": {
            "properties": {
              "op": {
                "const": "delete_field"
              }
            },
            "required": ["op"]
          },
          "then": {
            "required": ["field"]
          }
        }
      ]
    }
  }
}
